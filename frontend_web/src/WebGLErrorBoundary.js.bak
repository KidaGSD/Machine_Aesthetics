import React, { Component } from 'react';
import { applyWebGLPolyfill } from './WebGLPolyfill';

class WebGLErrorBoundary extends Component {
  constructor(props) {
    super(props);
    this.state = { 
      hasError: false,
      errorMessage: null,
      fallbackTriggered: false,
      forceFirstRender: true // Force at least one render attempt
    };
  }

  // Check if WebGL is supported - simplified version
  detectWebGL() {
    try {
      const canvas = document.createElement('canvas');
      const gl = canvas.getContext('webgl') || 
               canvas.getContext('webgl2') ||
               canvas.getContext('experimental-webgl');
      
      // If no context at all, we truly can't use WebGL
      if (!gl) {
        return false;
      }
      
      // Apply polyfill regardless of detection result
      applyWebGLPolyfill();
      
      // Instead of testing shader precision, try to apply a fix
      if (typeof gl.getShaderPrecisionFormat !== 'function') {
        gl.getShaderPrecisionFormat = function() {
          return {
            precision: 1,
            rangeMin: 1,
            rangeMax: 1024
          };
        };
      }
      
      // Assume WebGL is available if we got this far
      return true;
    } catch (e) {
      console.error("WebGL detection error:", e);
      return false;
    }
  }

  componentDidMount() {
    // Only set error state if WebGL is completely unavailable
    if (!this.detectWebGL() && !this.state.forceFirstRender) {
      this.setState({ 
        hasError: true, 
        errorMessage: "Your browser or device doesn't support WebGL, which is required for 3D graphics.",
        fallbackTriggered: true
      });
    }
  }

  static getDerivedStateFromError(error) {
    console.error("WebGL Error Boundary caught error:", error);
    
    // Extract useful information from the error
    let message = "A rendering error occurred in the 3D visualization";
    
    // Try to provide more specific error messages
    if (error.message) {
      if (error.message.includes("getShaderPrecisionFormat")) {
        message = "Your browser is missing WebGL shader precision support.";
      } else if (error.message.includes("INVALID_OPERATION")) {
        message = "WebGL rendering error: Invalid operation in 3D context.";
      } else if (error.message.includes("OUT_OF_MEMORY")) {
        message = "WebGL memory error: Your device ran out of graphics memory.";
      } else {
        message = error.message;
      }
    }
    
    return { 
      hasError: true, 
      errorMessage: message,
      fallbackTriggered: false,
      forceFirstRender: false
    };
  }

  componentDidCatch(error, errorInfo) {
    console.error("WebGL Error Details:", error);
    console.error("Component Stack:", errorInfo.componentStack);
    
    // Apply the polyfill regardless of error type
    applyWebGLPolyfill();
    
    // If this was our first render attempt, try again after applying polyfill
    if (this.state.forceFirstRender) {
      this.setState({ 
        hasError: false,
        fallbackTriggered: true,
        forceFirstRender: false
      });
    }
  }

  render() {
    // If we're forcing first render, always show children
    if (this.state.forceFirstRender) {
      return this.props.children;
    }
    
    // If there's an error but we have a fallback, use it
    if (this.state.hasError && this.props.fallback) {
      return this.props.fallback;
    }
    
    // If there's an error but no fallback, show error UI
    if (this.state.hasError) {
      return (
        <div className="webgl-error-container" style={{
          width: '100%',
          height: '100%',
          display: 'flex',
          flexDirection: 'column',
          justifyContent: 'center',
          alignItems: 'center',
          padding: '10px',
          textAlign: 'center',
          backgroundColor: '#1a1a1a',
          color: '#ffffff',
          borderRadius: '8px'
        }}>
          <div style={{
            background: 'rgba(255, 100, 0, 0.2)',
            padding: '10px',
            borderRadius: '8px',
            marginBottom: '12px'
          }}>
            <h3 style={{ margin: '0 0 10px 0', fontSize: '16px' }}>3D Visualization Error</h3>
            <p style={{ margin: '0', fontSize: '14px' }}>{this.state.errorMessage}</p>
          </div>
          
          <div style={{ fontSize: '12px', color: '#aaa', maxWidth: '280px' }}>
            <p style={{ margin: '0 0 5px 0' }}>Try these solutions:</p>
            <ul style={{ textAlign: 'left', paddingLeft: '20px', margin: '0' }}>
              <li>Refresh the page</li>
              <li>Update your browser</li>
              <li>Try Chrome, Firefox or Edge</li>
              <li>Enable hardware acceleration</li>
            </ul>
          </div>
          
          {/* Simple visualization fallback */}
          <div style={{ 
            width: '100%', 
            height: '120px', 
            marginTop: '15px', 
            borderTop: '1px solid #333',
            paddingTop: '10px'
          }}>
            <div style={{ 
              fontSize: '12px', 
              color: '#aaa', 
              marginBottom: '5px',
              textAlign: 'center' 
            }}>
              Simple Visualization
            </div>
            <div style={{ 
              width: '100%', 
              height: '100px', 
              display: 'flex',
              justifyContent: 'center',
              alignItems: 'center'
            }}>
              <svg width="100" height="100" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="40" stroke="#88ccff" strokeWidth="2" fill="none" />
                <circle cx="50" cy="50" r="30" stroke="#ffccaa" strokeWidth="2" fill="none" />
                <line x1="50" y1="10" x2="50" y2="90" stroke="#fff" strokeWidth="1" />
                <line x1="10" y1="50" x2="90" y2="50" stroke="#fff" strokeWidth="1" />
              </svg>
            </div>
          </div>
        </div>
      );
    }

    // No error, render children normally
    return this.props.children;
  }
}

export default WebGLErrorBoundary; 